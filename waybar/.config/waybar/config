	"battery", 
	"hyprland/language", 
	"clock"
    ],

    // Module specifics
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "on-click": "activate"
    },
    
    "hyprland/window": {
        "format": "{title}",
        "max-length": 50,
        "separate-outputs": true,
        "align": 0 // This explicitly tells Waybar to align the content to the left (0 = left, 0.5 = center, 1 = right)
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

