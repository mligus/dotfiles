{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,
    "exclusive": true,

    // Layout configuration
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    // "modules-center": ["hyprland/window"],
    "modules-right": [
        // "tray",
	"network",
	// "bluetooth",
